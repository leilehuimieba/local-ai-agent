{
  "name": "local-agent-frontend",
  "private": true,
  "version": "0.1.0",
  "description": "本地智能体前端 — React + Vite 驱动的智能体交互界面",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/leilehuimieba/local-ai-agent.git",
    "directory": "frontend"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\""
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^27.0.1",
    "prettier": "^3.5.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.31.0",
    "vite": "^8.0.1",
    "vitest": "^3.2.4"
  }
}
